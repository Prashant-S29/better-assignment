# Flask
SECRET_KEY=your-secret-key-change-this
FLASK_DEBUG=true

# Local db (local pg instance)
DATABASE_URL=postgresql://postgres:<your_password>@localhost:5432/better-assignment

# Prod db (Supabase)
# DATABASE_URL=


# JWT
JWT_SECRET=your-jwt-secret-change-this
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google SMTP
# Setup: Google Account → Security → 2-Step Verification → App Passwords → Generate
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# CORS — frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:5173

# PR size limit (additions + deletions)
PR_MAX_LINES=4000